{
  "name": "url-shortener-backend",
  "version": "1.0.0",
  "description": "Backend service for the URL shortener application",
  "main": "src/app.ts",
  "scripts": {
    "gen:templates": "node ./scripts/compile-emails.js",
    "dev": "nodemon",
    "build": "yarn gen:templates && tsc -noEmit && ts-node ./build.ts",
    "test": "jest",
    "prettier": "prettier --config ./.prettierrc.js --write \"src/**/*{.ts,.json}\"",
    "prettier:verify": "prettier --config ./.prettierrc.js --check \"src/**/*{.ts,.json}\"",
    "prettier:staged": "pretty-quick --staged",
    "prepare": "husky"
  },
  "author": "Nasirul Ahmed<nasirul369@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/view": "^11.1.1",
    "@socket.io/redis-adapter": "8.3.0",
    "@types/ejs": "^3.1.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.4",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "fastify": "^5.8.1",
    "fastify-plugin": "5.1.0",
    "geoip-lite": "2.0.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "5.10.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.6",
    "mjml": "^4.18.0",
    "mongoose": "9.2.4",
    "nanoid": "5.1.6",
    "nodemailer": "^8.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "13.1.3",
    "redlock": "5.0.0-beta.2",
    "reflect-metadata": "^0.1.13",
    "socket.io": "4.8.3",
    "typedi": "0.10.0",
    "ua-parser-js": "2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/geoip-lite": "1.4.4",
    "@types/jest": "30.0.0",
    "@types/node": "25.3.5",
    "@types/ua-parser-js": "0.7.39",
    "esbuild": "^0.27.4",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-pino": "2.3.3",
    "esbuild-plugin-tsc": "^0.5.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "4.2.1",
    "husky": "9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "16.4.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tslint": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "packages/**/src/**/*{.ts,.json}": [
      "prettier --config ./.prettierrc.js --write",
      "node --max_old_space_size=6096 ./node_modules/eslint/bin/eslint.js --fix"
    ]
  }
}
